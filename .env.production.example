# ═══════════════════════════════════════════════════════════════════
# TEMPLATE PRODUKSI UNTUK BUILD NATIVEPHP (DESKTOP OFFLINE)
# Salin ke .env sebelum menjalankan `php artisan native:build`
# JANGAN pernah commit file .env yang sebenarnya ke Git!
# ═══════════════════════════════════════════════════════════════════

APP_NAME="Rajawali POS & Stok"
APP_ENV=production
APP_KEY=           # WAJIB generate ulang tiap build: php artisan key:generate
APP_DEBUG=false    # ⚠️ WAJIB false — kalau true, error akan menampilkan stacktrace ke kasir
APP_URL=http://localhost

LOG_CHANNEL=daily
LOG_LEVEL=error

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=false   # false karena NativePHP jalan di http://localhost, bukan HTTPS
SESSION_SAME_SITE=lax

QUEUE_CONNECTION=sync   # Single-user desktop: tidak perlu queue worker terpisah di background

BCRYPT_ROUNDS=12

CACHE_STORE=file